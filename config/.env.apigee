# ═══════════════════════════════════════════════════════════════════════════
#  PRIMARY — DHL GenAI Gateway (Apigee)
# ═══════════════════════════════════════════════════════════════════════════
#
#  This is the PRODUCTION LLM backend for NgReact at DHL.
#  All LLM traffic routes through the DHL GenAI Gateway (Apigee proxy),
#  which fronts Azure OpenAI and Vertex AI deployments.
#
#  REQUIREMENTS
#    • You MUST be on the DHL corporate network (office LAN or DHL VPN).
#      The gateway rejects any request from an unauthorized network with
#      HTTP 403 "The request originated from an unauthorized network."
#    • APIGEE_API_KEY environment variable must be set with your DHL API key
#
#  USAGE (bash / WSL)
#    export APIGEE_API_KEY="your-key-here"
#    adk web . --port 8002
#
#  USAGE (PowerShell)
#    $env:APIGEE_API_KEY = "your-key-here"
#    adk web . --port 8002
# ═══════════════════════════════════════════════════════════════════════════

# ── LLM mode ─────────────────────────────────────────────────────────────────
NGREACT_LLM_MODE=apigee

# ── DHL GenAI Gateway ────────────────────────────────────────────────────────
# APIGEE_API_KEY must be set as an environment variable, NOT in this file
APIGEE_PROXY_URL_PRODUCTION=https://apihub-sandbox.eu.dhl.com/genai-sensitive
APIGEE_PROXY_URL_TESTING=https://apihub-sandbox.eu.dhl.com/genai-sensitive
APIGEE_ENVIRONMENT=testing

# ── Model deployment IDs (from models.prod.yaml) ─────────────────────────────
# VERTEX_MODEL left empty — the /vertexai endpoint returns 404 on this proxy.
APIGEE_DEFAULT_VERTEX_MODEL=
APIGEE_DEFAULT_AZURE_OPENAI_MODEL=gpt-4o-mini-2024-07-18-eudz
APIGEE_DEFAULT_EMBEDDING_MODEL=text-embedding-3-large-1-eudz

AZURE_API_VERSION=2025-03-01-preview
APIGEE_STREAMING_ENABLED=false
APIGEE_TIMEOUT_SECONDS=60

# ── Corporate proxy (OPTIONAL) ───────────────────────────────────────────────
# Only uncomment these if your network has NO direct route to the gateway and
# requires the DHL forward proxy. On most VPN setups the gateway is reachable
# directly, and setting an unreachable proxy here causes hard connection errors.
# If you get "ConnectError" / connection refused, try toggling these.
#HTTPS_PROXY=http://cloudproxy.dhl.com:80
#HTTP_PROXY=http://cloudproxy.dhl.com:80
#NO_PROXY=localhost,127.0.0.1,.dhl.com

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Optional: Qdrant knowledge base (leave blank to disable) ─────────────────
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_TIMEOUT_SECONDS=30.0
