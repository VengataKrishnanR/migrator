# ═══════════════════════════════════════════════════════════════════════════
#  NgReact Configuration — DHL GenAI Gateway (Apigee)
# ═══════════════════════════════════════════════════════════════════════════
#
#  This is an EXAMPLE configuration file for DHL Apigee.
#  DO NOT commit real API keys to version control.
#
#  Copy to .env and fill in your APIGEE_API_KEY:
#    cp config/.env.example .env
#    # Edit .env and add your APIGEE_API_KEY
# ═══════════════════════════════════════════════════════════════════════════

# ── LLM mode ─────────────────────────────────────────────────────────────────
NGREACT_LLM_MODE=apigee

# ── DHL GenAI Gateway (Apigee) ───────────────────────────────────────────────
# Get your API key from your DHL AI Champion
APIGEE_API_KEY=<paste-your-dhl-apigee-api-key-here>
APIGEE_PROXY_URL_PRODUCTION=https://apihub-sandbox.eu.dhl.com/genai-sensitive
APIGEE_PROXY_URL_TESTING=https://apihub-sandbox.eu.dhl.com/genai-sensitive
APIGEE_ENVIRONMENT=testing

# ── Model deployment IDs (from models.prod.yaml) ─────────────────────────────
APIGEE_DEFAULT_VERTEX_MODEL=
APIGEE_DEFAULT_AZURE_OPENAI_MODEL=gpt-4o-mini-2024-07-18-eudz
APIGEE_DEFAULT_EMBEDDING_MODEL=text-embedding-3-large-1-eudz

# ── API settings ─────────────────────────────────────────────────────────────
AZURE_API_VERSION=2025-03-01-preview
APIGEE_STREAMING_ENABLED=false
APIGEE_TIMEOUT_SECONDS=60

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Optional: Qdrant Vector Store (leave blank to disable) ─────────────────────
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_TIMEOUT_SECONDS=30.0

# ── Optional: Code Executor (for React sandbox execution) ───────────────────
CODE_EXECUTOR_URL=http://localhost:8100
